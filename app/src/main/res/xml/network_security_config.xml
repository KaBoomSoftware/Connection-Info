<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        ip-api.com free tier does not support HTTPS; all other traffic defaults to HTTPS-only.
    -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">ip-api.com</domain>
    </domain-config>
</network-security-config>
